<section id="contact" class="contact" data-section-num="015">
  <canvas id="contact-canvas" class="contact-canvas"></canvas>

  <div class="s-label" style="justify-content:center;position:relative;z-index:1;">{{ section.settings.label | default: '14 — Contact' }}</div>

  <div class="contact-avail reveal">
    <span class="contact-avail-dot"></span>
    {{ section.settings.availability_badge | default: 'Available for Projects' }}
  </div>

  <h2 class="contact-heading reveal">
    {{ section.settings.heading_1 | default: "Let's make" }}<br>
    <em>{{ section.settings.heading_2 | default: 'something' }}</em>
    {{ section.settings.heading_3 | default: 'real.' }}
  </h2>

  <p class="contact-sub reveal">
    {{ section.settings.sub_text | default: 'Available for film projects, creative direction, and collaborative storytelling. Cairo-based, globally minded.' }}
  </p>

  <!-- Direct email CTA -->
  <a href="mailto:{{ section.settings.email }}"
     class="contact-email reveal"
     id="contact-email-btn">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
      <polyline points="22,6 12,13 2,6"/>
    </svg>
    {{ section.settings.cta_label | default: section.settings.email }}
  </a>

  <!-- Contact form -->
  {% if section.settings.show_form %}
    <div class="contact-form-wrap reveal">
      {% form 'contact', class: 'contact-form' %}
        {% if form.posted_successfully? %}
          <div class="contact-form-success">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {{ section.settings.success_message | default: "Message sent. I'll be in touch." }}
          </div>
        {% else %}
          <div class="contact-form-fields">
            <div class="contact-form-row">
              <div class="contact-form-group">
                <label class="contact-form-label" for="contact-name">{{ section.settings.label_name | default: 'Name' }}</label>
                <input id="contact-name" class="contact-form-input" type="text" name="contact[name]"
                       placeholder="{{ section.settings.placeholder_name | default: 'Your name' }}" required>
              </div>
              <div class="contact-form-group">
                <label class="contact-form-label" for="contact-email">{{ section.settings.label_email | default: 'Email' }}</label>
                <input id="contact-email" class="contact-form-input" type="email" name="contact[email]"
                       placeholder="{{ section.settings.placeholder_email | default: 'your@email.com' }}" required>
              </div>
            </div>
            <div class="contact-form-group">
              <label class="contact-form-label" for="contact-project">{{ section.settings.label_project | default: 'Project type' }}</label>
              <select id="contact-project" class="contact-form-input contact-form-select" name="contact[Project type]">
                {% assign project_types = section.settings.project_types | split: ',' %}
                {% for type in project_types %}
                  <option value="{{ type | strip }}">{{ type | strip }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="contact-form-group">
              <label class="contact-form-label" for="contact-message">{{ section.settings.label_message | default: 'Message' }}</label>
              <textarea id="contact-message" class="contact-form-input contact-form-textarea"
                        name="contact[body]" rows="5"
                        placeholder="{{ section.settings.placeholder_message | default: 'Tell me about your project...' }}" required></textarea>
            </div>
            <button type="submit" class="contact-form-submit">
              {{ section.settings.submit_label | default: 'Send Message' }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
                <path d="M22 2L11 13M22 2L15 22 11 13 2 9l20-7z"/>
              </svg>
            </button>
          </div>
        {% endif %}
      {% endform %}
    </div>
  {% endif %}

  <div class="contact-loc reveal">
    {{ section.settings.location }}
    <em> · </em>
    {{ section.settings.location_sub | default: 'Available Worldwide' }}
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "14 — Contact"
    },
    {
      "type": "text",
      "id": "availability_badge",
      "label": "Availability badge",
      "default": "Available for Projects"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading line 1",
      "default": "Let's make"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading line 2 (italic gold)",
      "default": "something"
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Heading line 3",
      "default": "real."
    },
    {
      "type": "textarea",
      "id": "sub_text",
      "label": "Sub text",
      "default": "Available for film projects, creative direction, and collaborative storytelling. Cairo-based, globally minded."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@yourname.com"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Email button label",
      "default": "Get in touch"
    },
    {
      "type": "checkbox",
      "id": "show_form",
      "label": "Show contact form",
      "default": true
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "Form: Name label",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "Form: Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "label_project",
      "label": "Form: Project type label",
      "default": "Project type"
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "Form: Message label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "placeholder_name",
      "label": "Form: Name placeholder",
      "default": "Your name"
    },
    {
      "type": "text",
      "id": "placeholder_email",
      "label": "Form: Email placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "placeholder_message",
      "label": "Form: Message placeholder",
      "default": "Tell me about your project..."
    },
    {
      "type": "text",
      "id": "project_types",
      "label": "Project types (comma-separated)",
      "default": "Short Film,Documentary,Brand Campaign,Creative Direction,Sound Recording,Other"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Message sent. I'll be in touch."
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Cairo, Egypt"
    },
    {
      "type": "text",
      "id": "location_sub",
      "label": "Location sub",
      "default": "Available Worldwide"
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
