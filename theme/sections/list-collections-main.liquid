<div class="section lc-page">
  <div class="s-label reveal">Collections</div>
  <h1 class="lc-title reveal">Everything<br><em>we make.</em></h1>

  <div class="lc-grid">
    {% for collection in collections %}
      <a href="{{ collection.url }}" class="lc-card reveal" style="transition-delay:{{ forloop.index0 | times: 0.07 }}s;">
        {% if collection.image %}
          <div class="lc-card-img-wrap">
            <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.image.alt | escape | default: collection.title }}" class="lc-card-img" width="800" height="600" loading="lazy">
          </div>
        {% else %}
          <div class="lc-card-img-wrap lc-card-placeholder"></div>
        {% endif %}
        <div class="lc-card-body">
          <h2 class="lc-card-title">{{ collection.title }}</h2>
          <div class="lc-card-count">{{ collection.products_count }} items</div>
          {% if collection.description != blank %}
            <p class="lc-card-desc">{{ collection.description | strip_html | truncate: 80 }}</p>
          {% endif %}
          <span class="lc-card-cta">
            Browse
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="12" height="12"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% schema %}
{ "name": "Collections", "settings": [] }
{% endschema %}
