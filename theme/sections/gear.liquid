<section id="gear" class="section gear-section" data-section-num="021">
  <div class="s-label reveal">{{ section.settings.label | default: '20 — Gear' }}</div>
  <h2 class="gear-heading reveal">
    {{ section.settings.heading | default: 'Tools of' }}<br>
    <em>{{ section.settings.heading_em | default: 'the trade.' }}</em>
  </h2>
  <p class="gear-sub reveal reveal-delay-1">{{ section.settings.sub | default: 'The equipment behind every frame.' }}</p>

  <div class="gear-categories">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <div class="gear-category reveal" style="transition-delay: {{ forloop.index0 | times: 0.08 }}s;" {{ block.shopify_attributes }}>
          <div class="gear-category-head">
            <div class="gear-category-icon">
              {% case block.settings.icon %}
                {% when 'camera' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                {% when 'audio' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8"/></svg>
                {% when 'light' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                {% when 'edit' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
              {% endcase %}
            </div>
            <h3 class="gear-category-name">{{ block.settings.name | default: 'Category' }}</h3>
          </div>
          <ul class="gear-list">
            {% assign items = block.settings.items | split: '
' %}
            {% for item in items %}
              {% if item != blank %}
                <li class="gear-item">
                  <span class="gear-item-dot"></span>
                  {{ item | strip }}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Gear List",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "20 — Gear" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tools of" },
    { "type": "text", "id": "heading_em", "label": "Heading (italic gold)", "default": "the trade." },
    { "type": "textarea", "id": "sub", "label": "Subtext", "default": "The equipment behind every frame." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Gear category",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "camera", "label": "Camera" }, { "value": "audio", "label": "Audio" }, { "value": "light", "label": "Lighting" }, { "value": "edit", "label": "Editing" }, { "value": "other", "label": "Other" }], "default": "camera" },
        { "type": "text", "id": "name", "label": "Category name", "default": "Camera" },
        { "type": "textarea", "id": "items", "label": "Items (one per line)", "default": "Sony FX3\nSony A7 IV\nDJI RS3 Pro Gimbal" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Gear List",
    "blocks": [
      { "type": "category", "settings": { "icon": "camera", "name": "Camera", "items": "Sony FX3\nSony A7 IV\nDJI RS3 Pro Gimbal\nSmallRig Cage + Rigs" } },
      { "type": "category", "settings": { "icon": "audio", "name": "Audio", "items": "Sennheiser MKH416\nZoom F6 Field Recorder\nRode Wireless GO II\nDead cat windshield" } },
      { "type": "category", "settings": { "icon": "light", "name": "Lighting", "items": "Aputure 300d II\nNanlite Forza 60\nV-flat diffusion panels\nLED practical bulbs" } },
      { "type": "category", "settings": { "icon": "edit", "name": "Post", "items": "DaVinci Resolve Studio\nAdobe Premiere Pro\nAfter Effects\nFinal Cut Pro" } }
    ]
  }]
}
{% endschema %}
