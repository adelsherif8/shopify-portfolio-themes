<section id="craft" class="section" data-section-num="009">
  <div class="s-label reveal">{{ section.settings.label | default: '08 — Craft' }}</div>

  <div class="craft-top">
    <h2 class="craft-heading reveal">
      {{ section.settings.heading_1 | default: 'Behind' }}<br>
      {{ section.settings.heading_2 | default: 'the ' }}<em>{{ section.settings.heading_3 | default: 'Lens' }}</em>
    </h2>
    <p class="craft-desc reveal reveal-delay-1">{{ section.settings.description | default: 'Every discipline in service of the story. The tools are secondary to the intent behind them.' }}</p>
  </div>

  <div class="craft-frames">
    {% for block in section.blocks %}
      {% if block.type == 'frame' %}
        <div class="craft-frame reveal" style="transition-delay: {{ forloop.index0 | times: 0.1 }}s;" {{ block.shopify_attributes }}>
          <div class="craft-frame-lines"></div>
          <div class="craft-frame-content">
            <div class="craft-frame-icon">
              {% case block.settings.icon %}
                {% when 'camera' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path d="M14.5 4h-5L7 7H4a2 2 0 00-2 2v9a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2h-3l-2.5-3z"/>
                    <circle cx="12" cy="13" r="3"/>
                  </svg>
                {% when 'pen' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
                  </svg>
                {% when 'mic' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
                    <path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/>
                  </svg>
                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                    <circle cx="12" cy="12" r="10"/>
                  </svg>
              {% endcase %}
            </div>
            <div class="craft-frame-lbl">{{ block.settings.label }}</div>
            <div class="craft-frame-title">{{ block.settings.title }}</div>
          </div>
          <span class="craft-frame-cn">F0{{ forloop.index }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="craft-radar-wrap">
    <svg id="craft-radar" class="craft-radar" viewBox="0 0 400 400"></svg>
    <div class="craft-skills">
      {% for block in section.blocks %}
        {% if block.type == 'skill' %}
          <div class="craft-skill reveal" style="transition-delay: {{ forloop.index0 | times: 0.04 }}s;" {{ block.shopify_attributes }}>
            <span class="craft-skill-dot"></span>
            <div>
              <div class="craft-skill-name">{{ block.settings.name }}</div>
              <div class="craft-skill-sub">{{ block.settings.sub }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Craft & Skills",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "08 — Craft"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading line 1",
      "default": "Behind"
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading line 2",
      "default": "the "
    },
    {
      "type": "text",
      "id": "heading_3",
      "label": "Heading line 3 (italic gold)",
      "default": "Lens"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every discipline in service of the story. The tools are secondary to the intent behind them."
    }
  ],
  "blocks": [
    {
      "type": "frame",
      "name": "Discipline frame",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "camera", "label": "Camera" },
            { "value": "pen",    "label": "Pen" },
            { "value": "mic",    "label": "Microphone" }
          ],
          "default": "camera"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Directing"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The eye behind the frame"
        }
      ]
    },
    {
      "type": "skill",
      "name": "Skill",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Skill name",
          "default": "Script Writing"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "Sub-skills",
          "default": "Structure · Dialogue · Arc"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craft & Skills",
      "blocks": [
        { "type": "frame", "settings": { "icon": "camera", "label": "Directing",       "title": "The eye behind the frame" } },
        { "type": "frame", "settings": { "icon": "pen",    "label": "Screenwriting",   "title": "Where every story begins" } },
        { "type": "frame", "settings": { "icon": "mic",    "label": "Sound Recording", "title": "Capturing the invisible"  } },
        { "type": "skill", "settings": { "name": "Script Writing",      "sub": "Structure · Dialogue · Arc" } },
        { "type": "skill", "settings": { "name": "Film Production",     "sub": "Pre · Shoot · Post" } },
        { "type": "skill", "settings": { "name": "Sound Recording",     "sub": "Field · Boom · Location" } },
        { "type": "skill", "settings": { "name": "Creative Direction",  "sub": "Vision · Identity · Campaign" } },
        { "type": "skill", "settings": { "name": "Visual Storytelling", "sub": "Frame · Light · Composition" } },
        { "type": "skill", "settings": { "name": "Set Collaboration",   "sub": "Crew · Communication · Flow" } },
        { "type": "skill", "settings": { "name": "Story Development",   "sub": "Concept · Theme · Narrative" } },
        { "type": "skill", "settings": { "name": "Directing",           "sub": "Cast · Frame · Emotion" } }
      ]
    }
  ]
}
{% endschema %}
