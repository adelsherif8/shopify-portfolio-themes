<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; background: var(--black, #040404); color: var(--text, rgba(255,255,255,.88)); font-family: 'Space Mono', monospace; overflow: hidden; }
  .pw-canvas { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; opacity: .7; }
  .pw-letterbox { position: fixed; left: 0; right: 0; height: 48px; background: #000; z-index: 2; }
  .pw-letterbox--top { top: 0; } .pw-letterbox--bot { bottom: 0; }
  .pw-scanlines { position: fixed; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,.06) 2px, rgba(0,0,0,.06) 4px); pointer-events: none; z-index: 1; }
  .pw-corner { position: fixed; width: 20px; height: 20px; border-color: rgba(184,151,58,.35); border-style: solid; z-index: 3; }
  .pw-corner-tl { top: 60px; left: 24px; border-width: 1px 0 0 1px; }
  .pw-corner-tr { top: 60px; right: 24px; border-width: 1px 1px 0 0; }
  .pw-corner-bl { bottom: 60px; left: 24px; border-width: 0 0 1px 1px; }
  .pw-corner-br { bottom: 60px; right: 24px; border-width: 0 1px 1px 0; }
  .pw-film-num { position: fixed; bottom: 60px; right: 40px; font-size: 8px; letter-spacing: .3em; color: rgba(184,151,58,.4); text-transform: uppercase; z-index: 3; }
  .pw-scene-num { position: fixed; top: 60px; left: 40px; font-size: 8px; letter-spacing: .3em; color: rgba(184,151,58,.3); z-index: 3; }
  .pw-wrap { position: relative; z-index: 4; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 32px; text-align: center; }
  .pw-eyebrow { font-size: 9px; letter-spacing: .4em; text-transform: uppercase; color: var(--gold, #b8973a); margin-bottom: 32px; }
  .pw-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(44px, 9vw, 96px); font-weight: 200; line-height: .92; color: var(--text, rgba(255,255,255,.88)); margin-bottom: 28px; }
  .pw-heading em { font-style: italic; color: var(--gold, #b8973a); display: block; }
  .pw-sub { font-size: 11px; letter-spacing: .18em; color: rgba(255,255,255,.35); margin-bottom: 56px; max-width: 420px; line-height: 1.9; }
  .pw-countdown { display: flex; gap: 2px; margin-bottom: 56px; align-items: flex-end; }
  .pw-countdown-unit { display: flex; flex-direction: column; align-items: center; min-width: 72px; }
  .pw-countdown-num { font-family: 'Cormorant Garamond', serif; font-size: clamp(36px, 6vw, 56px); font-weight: 200; color: var(--text, rgba(255,255,255,.88)); line-height: 1; border: 1px solid rgba(184,151,58,.2); padding: 12px 16px; background: rgba(184,151,58,.04); min-width: 72px; text-align: center; }
  .pw-countdown-label { font-size: 7px; letter-spacing: .3em; text-transform: uppercase; color: rgba(184,151,58,.5); margin-top: 8px; }
  .pw-countdown-sep { font-family: 'Cormorant Garamond', serif; font-size: 36px; font-weight: 200; color: rgba(184,151,58,.25); padding: 0 4px 16px; line-height: 1; }
  .pw-countdown[data-hidden] { display: none; }
  .pw-forms { display: flex; flex-direction: column; gap: 16px; align-items: center; width: 100%; max-width: 440px; }
  .pw-form { display: flex; width: 100%; border: 1px solid rgba(255,255,255,.1); }
  .pw-input { flex: 1; background: transparent; border: none; padding: 14px 20px; font-family: 'Space Mono', monospace; font-size: 11px; color: var(--text, rgba(255,255,255,.88)); outline: none; letter-spacing: .06em; }
  .pw-input::placeholder { color: rgba(255,255,255,.25); }
  .pw-btn { background: var(--gold, #b8973a); color: #040404; border: none; padding: 14px 24px; font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: .22em; text-transform: uppercase; cursor: pointer; transition: background .2s; white-space: nowrap; }
  .pw-btn:hover { background: var(--gold2, #d4af6a); }
  .pw-error { font-size: 9px; letter-spacing: .15em; color: rgba(220,80,80,.8); margin-bottom: 8px; }
  .pw-or { font-size: 8px; letter-spacing: .3em; color: rgba(255,255,255,.2); text-transform: uppercase; display: flex; align-items: center; gap: 12px; width: 100%; }
  .pw-or::before, .pw-or::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,.06); }
  .pw-notify-label { font-size: 8px; letter-spacing: .25em; color: rgba(255,255,255,.3); text-transform: uppercase; margin-bottom: 4px; }
  .pw-notify-success { font-size: 9px; letter-spacing: .15em; color: var(--gold, #b8973a); display: none; }
  .pw-notify-success.show { display: block; }
  .pw-social { display: flex; gap: 16px; margin-top: 40px; }
  .pw-social-link { width: 36px; height: 36px; border: 1px solid rgba(255,255,255,.08); color: rgba(255,255,255,.3); display: flex; align-items: center; justify-content: center; transition: border-color .2s, color .2s; text-decoration: none; }
  .pw-social-link:hover { border-color: var(--gold, #b8973a); color: var(--gold, #b8973a); }
  @media (max-width: 600px) { .pw-countdown { gap: 1px; } .pw-countdown-unit { min-width: 56px; } .pw-countdown-num { min-width: 56px; font-size: 28px; padding: 10px 12px; } }
</style>

<canvas id="pw-canvas" class="pw-canvas"></canvas>
<div class="pw-scanlines"></div>
<div class="pw-letterbox pw-letterbox--top"></div>
<div class="pw-letterbox pw-letterbox--bot"></div>
<div class="pw-corner pw-corner-tl"></div>
<div class="pw-corner pw-corner-tr"></div>
<div class="pw-corner pw-corner-bl"></div>
<div class="pw-corner pw-corner-br"></div>
<div class="pw-film-num">SCENE 001 · ROLL A</div>
<div class="pw-scene-num" id="pw-scene-roll">00:00:00:00</div>

<div class="pw-wrap">
  <div class="pw-eyebrow">{{ shop.name }}</div>

  <h1 class="pw-heading">
    {{ section.settings.heading | default: 'Something is' }}<br>
    <em>{{ section.settings.heading_em | default: 'in development.' }}</em>
  </h1>
  <p class="pw-sub">{{ section.settings.subtext | default: shop.password_message | default: 'The frame is not ready yet. Enter the password to get early access, or leave your email to be notified when we launch.' }}</p>

  <div class="pw-countdown" id="pw-countdown" data-target="{{ section.settings.launch_date | default: '' }}">
    <div class="pw-countdown-unit"><div class="pw-countdown-num" id="pw-days">00</div><div class="pw-countdown-label">Days</div></div>
    <div class="pw-countdown-sep">:</div>
    <div class="pw-countdown-unit"><div class="pw-countdown-num" id="pw-hours">00</div><div class="pw-countdown-label">Hours</div></div>
    <div class="pw-countdown-sep">:</div>
    <div class="pw-countdown-unit"><div class="pw-countdown-num" id="pw-mins">00</div><div class="pw-countdown-label">Mins</div></div>
    <div class="pw-countdown-sep">:</div>
    <div class="pw-countdown-unit"><div class="pw-countdown-num" id="pw-secs">00</div><div class="pw-countdown-label">Secs</div></div>
  </div>

  <div class="pw-forms">
    {% form 'storefront_password' %}
      {% if form.errors %}
        <p class="pw-error">{{ form.errors | default_errors }}</p>
      {% endif %}
      <div class="pw-form">
        <label for="password" class="visually-hidden">Password</label>
        <input type="password" name="password" id="password" class="pw-input" placeholder="{{ section.settings.password_placeholder | default: 'Enter password' }}" autocomplete="current-password">
        <button type="submit" class="pw-btn">{{ section.settings.password_btn | default: 'Enter' }}</button>
      </div>
    {% endform %}

    <div class="pw-or">or</div>

    <p class="pw-notify-label">{{ section.settings.notify_label | default: 'Notify me when we launch' }}</p>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter,notify-on-launch">
      <div class="pw-form">
        <label for="notify-email" class="visually-hidden">Email address</label>
        <input type="email" name="contact[email]" id="notify-email" class="pw-input" placeholder="your@email.com" autocomplete="email">
        <button type="submit" class="pw-btn">{{ section.settings.notify_btn | default: 'Notify me' }}</button>
      </div>
      {% if form.posted_successfully? %}
        <p class="pw-notify-success show">{{ section.settings.notify_success | default: "You're on the list. We'll be in touch." }}</p>
      {% endif %}
    {% endform %}
  </div>

  <div class="pw-social">
    {% if settings.social_instagram != blank %}
      <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" class="pw-social-link" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
      </a>
    {% endif %}
    {% if settings.social_vimeo != blank %}
      <a href="{{ settings.social_vimeo }}" target="_blank" rel="noopener" class="pw-social-link" aria-label="Vimeo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M22 7.4c-.1 2.8-2 6.6-5.7 11.4C12.4 23.6 9.4 24 7.8 24c-1.8 0-3.3-1.7-4.6-5L1.8 14C.9 11 0 9.3 0 9.3s1.4 1.1 2.6 0C4 8 5.5 6 6.4 4.7 7.9 2.7 9 1.8 9.7 1.8c.9 0 1.4.7 1.7 2l1.5 5.8c.4 1.6.9 2.4 1.4 2.4.4 0 1.1-.5 2-1.6.9-1.1 1.4-1.9 1.4-2.6 0-1-.8-1.5-2.4-1.5.9-2.8 2.5-4.2 4.9-4.2 1.8.1 2.6 1.2 2.8 3.3z"/></svg>
      </a>
    {% endif %}
    {% if settings.social_youtube != blank %}
      <a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" class="pw-social-link" aria-label="YouTube">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.95C5.12 20 12 20 12 20s6.88 0 8.59-.47a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
      </a>
    {% endif %}
  </div>
</div>

<script>
(function(){
  const canvas = document.getElementById('pw-canvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    let W, H, frame = 0;
    function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    function drawGrain() {
      frame++;
      if (frame % 2 !== 0) { requestAnimationFrame(drawGrain); return; }
      const img = ctx.createImageData(W, H); const d = img.data;
      for (let i = 0; i < d.length; i += 4) { const v = Math.random() * 28; d[i] = d[i+1] = d[i+2] = v; d[i+3] = 255; }
      ctx.putImageData(img, 0, 0); requestAnimationFrame(drawGrain);
    }
    drawGrain();
  }
  const sceneRoll = document.getElementById('pw-scene-roll');
  if (sceneRoll) {
    function tickTimecode() {
      const n = new Date(); const pad = v => String(v).padStart(2,'0');
      const fr = Math.floor((n.getMilliseconds()/1000)*24);
      sceneRoll.textContent = [pad(n.getHours()),pad(n.getMinutes()),pad(n.getSeconds()),pad(fr)].join(':');
    }
    setInterval(tickTimecode, 41); tickTimecode();
  }
  const cdEl = document.getElementById('pw-countdown');
  const target = cdEl && cdEl.dataset.target;
  if (target && target.trim()) {
    const end = new Date(target).getTime();
    if (!isNaN(end)) {
      function tickCountdown() {
        const diff = end - Date.now();
        if (diff <= 0) { cdEl.setAttribute('data-hidden',''); return; }
        const pad = v => String(v).padStart(2,'0');
        document.getElementById('pw-days').textContent  = pad(Math.floor(diff/86400000));
        document.getElementById('pw-hours').textContent = pad(Math.floor((diff%86400000)/3600000));
        document.getElementById('pw-mins').textContent  = pad(Math.floor((diff%3600000)/60000));
        document.getElementById('pw-secs').textContent  = pad(Math.floor((diff%60000)/1000));
      }
      tickCountdown(); setInterval(tickCountdown, 1000);
    } else { cdEl.setAttribute('data-hidden',''); }
  } else if (cdEl) { cdEl.setAttribute('data-hidden',''); }
})();
</script>

{% schema %}
{
  "name": "Password page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Something is" },
    { "type": "text", "id": "heading_em", "label": "Heading emphasis (italic line)", "default": "in development." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The frame is not ready yet. Enter the password to get early access, or leave your email to be notified when we launch." },
    { "type": "text", "id": "launch_date", "label": "Launch date (YYYY-MM-DD)", "info": "Leave empty to hide countdown." },
    { "type": "text", "id": "password_placeholder", "label": "Password field placeholder", "default": "Enter password" },
    { "type": "text", "id": "password_btn", "label": "Password button label", "default": "Enter" },
    { "type": "text", "id": "notify_label", "label": "Notification label", "default": "Notify me when we launch" },
    { "type": "text", "id": "notify_btn", "label": "Notification button label", "default": "Notify me" },
    { "type": "text", "id": "notify_success", "label": "Success message", "default": "You're on the list. We'll be in touch." }
  ]
}
{% endschema %}
