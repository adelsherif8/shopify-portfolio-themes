{% assign coll = collections[section.settings.collection] %}

<section class="section fc-section">

  <div class="fc-header reveal">
    {% if section.settings.label != blank %}
      <div class="s-label" style="justify-content:center;margin-bottom:20px;">{{ section.settings.label }}</div>
    {% endif %}
    <h2 class="fc-heading">
      {{ section.settings.heading_prefix | default: 'Shop the ' }}<em>{{ section.settings.heading_em | default: 'collection.' }}</em>
    </h2>
    {% if section.settings.subtext != blank %}
      <p class="fc-sub">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>

  {% if coll != blank %}
    <div class="fc-grid">
      {% for product in coll.products limit: section.settings.products_to_show %}
        <div class="coll-card reveal" style="transition-delay: {{ forloop.index0 | modulo: 4 | times: 0.07 }}s;">
          <a href="{{ product.url }}" class="coll-card-link">
            <div class="coll-card-img-wrap">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 600 }}"
                     alt="{{ product.featured_image.alt | escape | default: product.title }}"
                     class="coll-card-img" width="600" height="600" loading="lazy">
                {% if product.images[1] %}
                  <img src="{{ product.images[1] | image_url: width: 600 }}"
                       alt="{{ product.title | escape }}"
                       class="coll-card-img coll-card-img--hover" width="600" height="600" loading="lazy">
                {% endif %}
              {% else %}
                <div class="coll-card-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="36" height="36" style="color:var(--gold);opacity:.2;">
                    <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}

              <div class="coll-card-badges">
                {% if product.available == false %}
                  <span class="coll-badge coll-badge--soldout">Sold out</span>
                {% elsif product.compare_at_price > product.price %}
                  <span class="coll-badge coll-badge--sale">Sale</span>
                {% endif %}
                {% if product.tags contains 'new' or product.tags contains 'New' %}
                  <span class="coll-badge coll-badge--new">New</span>
                {% endif %}
              </div>

              <button class="coll-qv-btn" data-product-url="{{ product.url }}" aria-label="Quick view {{ product.title | escape }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Quick View
              </button>
            </div>

            <div class="coll-card-info">
              {% if product.type != blank %}
                <div class="coll-card-type">{{ product.type }}</div>
              {% endif %}
              <h3 class="coll-card-title">{{ product.title }}</h3>
              <div class="coll-card-price-row">
                {% if product.compare_at_price > product.price %}
                  <s class="coll-card-compare">{{ product.compare_at_price | money }}</s>
                {% endif %}
                <span class="coll-card-price">{{ product.price | money }}</span>
              </div>
              {% unless product.has_only_default_variant %}
                <div class="coll-card-variants">{{ product.variants.size }} options</div>
              {% endunless %}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_view_all and coll.products_count > section.settings.products_to_show %}
      <div class="fc-view-all reveal">
        <a href="{{ coll.url }}" class="fc-view-all-btn">
          {{ section.settings.view_all_label | default: 'View all' }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    {% endif %}

  {% else %}
    <div class="fc-empty">
      <p>Select a collection in the theme editor to display products here.</p>
    </div>
  {% endif %}

</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "— Shop"
    },
    {
      "type": "text",
      "id": "heading_prefix",
      "label": "Heading prefix",
      "default": "Shop the "
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading (italic gold)",
      "default": "collection."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext (optional)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "'View all' button label",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
