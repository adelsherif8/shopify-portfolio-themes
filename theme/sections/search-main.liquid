<div class="section search-page">
  <div class="s-label reveal">Search</div>
  <h1 class="search-page-title reveal">Find<br><em>anything.</em></h1>

  <form action="{{ routes.search_url }}" method="get" class="search-form reveal" role="search">
    <input type="hidden" name="type" value="product,article,page">
    <div class="search-input-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="search" name="q" class="search-input" value="{{ search.terms | escape }}" placeholder="Search products, journal, pages…" aria-label="Search" autocomplete="off">
      <button type="submit" class="search-submit">Search</button>
    </div>
  </form>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="search-meta reveal">{{ search.results_count }} result{{ search.results_count | pluralize: '', 's' }} for <em>"{{ search.terms }}"</em></div>
      {% paginate search.results by 20 %}
        <div class="search-results">
          {% for result in search.results %}
            <a href="{{ result.url }}" class="search-result reveal" style="transition-delay:{{ forloop.index0 | times: 0.04 }}s;">
              <div class="search-result-img-wrap">
                {% if result.featured_image or result.image %}
                  <img src="{{ result.featured_image | default: result.image | image_url: width: 200 }}" alt="" width="200" height="200" loading="lazy" class="search-result-img">
                {% else %}
                  <div class="search-result-placeholder"></div>
                {% endif %}
              </div>
              <div class="search-result-body">
                <div class="search-result-type">{{ result.object_type | capitalize }}</div>
                <div class="search-result-title">{{ result.title }}</div>
                {% if result.price %}
                  <div class="search-result-price">{{ result.price | money }}</div>
                {% endif %}
                {% if result.content or result.body %}
                  <p class="search-result-excerpt">{{ result.content | default: result.body | strip_html | truncate: 100 }}</p>
                {% endif %}
              </div>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" class="search-result-arrow"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {% endfor %}
        </div>
        {% if paginate.pages > 1 %}
          <div class="coll-pagination">
            {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="coll-page-btn">← Prev</a>{% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}<a href="{{ part.url }}" class="coll-page-num">{{ part.title }}</a>
              {% elsif part.title == paginate.current_page %}<span class="coll-page-num active">{{ part.title }}</span>
              {% else %}<span class="coll-page-ellipsis">…</span>{% endif %}
            {% endfor %}
            {% if paginate.next %}<a href="{{ paginate.next.url }}" class="coll-page-btn">Next →</a>{% endif %}
          </div>
        {% endif %}
      {% endpaginate %}
    {% else %}
      <div class="search-empty reveal">
        <p>No results for <em>"{{ search.terms }}"</em>. Try a different search.</p>
      </div>
    {% endif %}
  {% endif %}
</div>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
