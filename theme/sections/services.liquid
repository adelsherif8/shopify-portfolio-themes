<section id="services" class="section" data-section-num="016">
  <div class="s-label reveal">{{ section.settings.label | default: 'Services & Rates' }}</div>
  <h2 class="services-heading reveal">
    {{ section.settings.heading_1 | default: 'What I ' }}<em>{{ section.settings.heading_2 | default: 'bring to your project.' }}</em>
  </h2>
  {% if section.settings.intro != blank %}
    <p class="services-intro reveal">{{ section.settings.intro }}</p>
  {% endif %}

  <div class="services-grid">
    {% for block in section.blocks %}
      {% if block.type == 'service' %}
        <div class="service-card reveal" style="transition-delay:{{ forloop.index0 | times: 0.1 }}s;" {{ block.shopify_attributes }}>
          <div class="service-card-top">
            <div class="service-icon">
              {% render 'icon', icon: block.settings.icon, size: 22 %}
            </div>
            <div class="service-num">0{{ forloop.index }}</div>
          </div>
          <h3 class="service-title">{{ block.settings.title }}</h3>
          <p class="service-desc">{{ block.settings.description }}</p>
          {% if block.settings.highlights != blank %}
            <ul class="service-highlights">
              {% assign items = block.settings.highlights | split: '|' %}
              {% for item in items %}
                <li>{{ item | strip }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if block.settings.price != blank %}
            <div class="service-price">
              <span class="service-price-label">{{ section.settings.from_label | default: 'From' }}</span>
              <span class="service-price-val">{{ block.settings.price }}</span>
            </div>
          {% endif %}
          {% if block.settings.cta_label != blank and block.settings.cta_url != blank %}
            <a href="{{ block.settings.cta_url }}" class="service-cta">
              {{ block.settings.cta_label }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          {% endif %}
          <div class="service-card-line"></div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if section.settings.note != blank %}
    <p class="services-note reveal">{{ section.settings.note }}</p>
  {% endif %}
</section>

{% schema %}
{
  "name": "Services & Rates",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Services & Rates"
    },
    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading prefix",
      "default": "What I "
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading (italic gold)",
      "default": "bring to your project."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text (optional)"
    },
    {
      "type": "text",
      "id": "from_label",
      "label": "Price 'From' label",
      "default": "From"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Footer note (optional)",
      "default": "All rates are negotiable based on project scope, timeline, and budget. Reach out to discuss."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "film",
          "options": [
            { "value": "film",       "label": "Film strip" },
            { "value": "screenplay", "label": "Screenplay / Script" },
            { "value": "direction",  "label": "Direction / Clapperboard" },
            { "value": "creative",   "label": "Creative direction" },
            { "value": "sound",      "label": "Sound / Microphone" },
            { "value": "camera",     "label": "Camera" },
            { "value": "edit",       "label": "Editing / Scissors" },
            { "value": "photo",      "label": "Photography" },
            { "value": "brand",      "label": "Brand" },
            { "value": "star",       "label": "Star" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Service title",
          "default": "Screenwriting"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Original screenplays, script development, story consulting, and dialogue polish."
        },
        {
          "type": "textarea",
          "id": "highlights",
          "label": "Highlights (pipe-separated)",
          "default": "Original screenplay|Story development|Script consultation|Dialogue polish"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price / rate (e.g. $500, $80/hr)",
          "info": "Leave blank to hide"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Enquire"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Services & Rates",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "screenplay",
            "title": "Screenwriting",
            "description": "Original screenplays, script development, story consulting — from concept to final draft.",
            "highlights": "Original screenplay|Story development|Script consultation|Dialogue polish"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "direction",
            "title": "Film Direction",
            "description": "End-to-end direction for short films, branded content, and documentary productions.",
            "highlights": "Pre-production planning|On-set direction|Actor coaching|Creative oversight"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "creative",
            "title": "Creative Direction",
            "description": "Visual identity, campaign concept, and creative strategy for brands and productions.",
            "highlights": "Campaign concept|Visual identity|Brand storytelling|Art direction"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "sound",
            "title": "Sound Recording",
            "description": "Field and studio audio capture for film, documentary, and commercial productions.",
            "highlights": "Boom operation|Field recording|Location sound|Audio monitoring"
          }
        }
      ]
    }
  ]
}
{% endschema %}
