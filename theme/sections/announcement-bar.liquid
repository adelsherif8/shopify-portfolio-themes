{% if section.settings.enabled %}
  <div class="announcement-bar" id="announcement-bar" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
    <div class="announcement-bar-inner">
      {% if section.settings.icon != blank %}
        <span class="announcement-icon">{{ section.settings.icon }}</span>
      {% endif %}
      <span class="announcement-text">{{ section.settings.text | default: 'Free shipping on orders over $100' }}</span>
      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="announcement-link" style="color:{{ section.settings.text_color }};">{{ section.settings.link_label }} →</a>
      {% endif %}
    </div>
    {% if section.settings.dismissible %}
      <button class="announcement-close" id="announcement-close" aria-label="Dismiss">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    {% endif %}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "text", "label": "Message", "default": "Free worldwide shipping on orders over $150" },
    { "type": "text", "id": "icon", "label": "Icon / emoji (optional)", "default": "✦" },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "text", "id": "link_label", "label": "Link label" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#b8973a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#040404" },
    { "type": "checkbox", "id": "dismissible", "label": "Allow dismissing", "default": true }
  ]
}
{% endschema %}
