<div class="pdp" id="pdp">

  <!-- ── GALLERY ── -->
  <div class="pdp-gallery" id="pdp-gallery">
    <div class="pdp-gallery-main" id="pdp-gallery-main">
      {% for media in product.media %}
        <div class="pdp-media-slide {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
          {% if media.media_type == 'video' %}
            <video class="pdp-media-video" autoplay muted loop playsinline>
              {% for source in media.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
            </video>
          {% else %}
            <img src="{{ media | image_url: width: 1200 }}"
                 alt="{{ media.alt | escape | default: product.title }}"
                 class="pdp-media-img" width="1200" height="1200" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
          {% endif %}
          <div class="pdp-media-scanlines"></div>
        </div>
      {% else %}
        <div class="pdp-media-slide active">
          <div class="pdp-media-placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="48" height="48" style="color:var(--gold);opacity:.2;">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
        </div>
      {% endfor %}

      <!-- corner marks -->
      <div class="pdp-corner pdp-corner-tl"></div>
      <div class="pdp-corner pdp-corner-tr"></div>
      <div class="pdp-corner pdp-corner-bl"></div>
      <div class="pdp-corner pdp-corner-br"></div>

      <!-- film number -->
      <div class="pdp-film-num">{{ product.metafields.custom.scene_num | default: 'SCENE 001 · ROLL A' }}</div>
    </div>

    {% if product.media.size > 1 %}
      <div class="pdp-thumbs" id="pdp-thumbs">
        {% for media in product.media %}
          <button class="pdp-thumb {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
            <img src="{{ media | image_url: width: 160 }}" alt="" width="160" height="160" loading="lazy">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- ── INFO PANEL ── -->
  <div class="pdp-info">

    <!-- breadcrumb -->
    <div class="pdp-breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span>/</span>
      {% if product.collections.first %}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span>/</span>
      {% endif %}
      <span>{{ product.title }}</span>
    </div>

    <!-- type + badges -->
    <div class="pdp-meta-row">
      {% if product.type != blank %}
        <span class="pdp-product-type">{{ product.type }}</span>
      {% endif %}
      {% if product.tags contains 'new' or product.tags contains 'New' %}
        <span class="pdp-badge pdp-badge--new">New</span>
      {% endif %}
      {% if product.compare_at_price_max and product.compare_at_price_max > product.price %}
        <span class="pdp-badge pdp-badge--sale">Sale</span>
      {% endif %}
    </div>

    <h1 class="pdp-title">{{ product.title }}</h1>

    {% if product.metafields.custom.subtitle != blank %}
      <div class="pdp-subtitle">{{ product.metafields.custom.subtitle }}</div>
    {% endif %}

    <!-- Price -->
    {% assign v = product.selected_or_first_available_variant %}
    <div class="pdp-price-wrap" id="pdp-price-wrap">
      {% if v.compare_at_price and v.compare_at_price > v.price %}
        <s class="pdp-price-compare" id="pdp-price-compare">{{ v.compare_at_price | money }}</s>
      {% endif %}
      <span class="pdp-price" id="pdp-price">{{ v.price | money }}</span>
      {% if v.compare_at_price and v.compare_at_price > v.price %}
        <span class="pdp-price-save" id="pdp-price-save">Save {{ v.compare_at_price | minus: v.price | money }}</span>
      {% endif %}
      {% if v.unit_price %}
        <div class="pdp-unit-price" id="pdp-unit-price">
          {{ v.unit_price | money }}<span class="pdp-unit-sep">/</span>{{ v.unit_price_measurement.reference_value }}{{ v.unit_price_measurement.reference_unit }}
        </div>
      {% endif %}
    </div>
    {% if cart.taxes_included %}
      <p class="pdp-tax-note">Tax included.</p>
    {% endif %}

    <!-- Short description / logline -->
    {% if product.metafields.custom.logline != blank %}
      <p class="pdp-logline">{{ product.metafields.custom.logline }}</p>
    {% endif %}

    <!-- Variants -->
    {% unless product.has_only_default_variant %}
      <div class="pdp-variants">
        {% for option in product.options_with_values %}
          <div class="pdp-option">
            <div class="pdp-option-label">
              {{ option.name }}
              {% if option.name == 'Color' or option.name == 'Colour' %}
                <span class="pdp-option-selected" id="selected-{{ option.name | handle }}">{{ option.selected_value }}</span>
              {% endif %}
            </div>
            <div class="pdp-option-values">
              {% for value in option.values %}
                {% assign variant_available = false %}
                {% for variant in product.variants %}
                  {% if variant.options contains value and variant.available %}
                    {% assign variant_available = true %}
                  {% endif %}
                {% endfor %}
                <button class="pdp-option-btn {% if option.selected_value == value %}active{% endif %} {% unless variant_available %}sold-out{% endunless %}"
                        data-option="{{ option.name }}"
                        data-value="{{ value }}"
                        aria-label="{{ value }}{% unless variant_available %} - Sold out{% endunless %}"
                        {% if option.name == 'Color' or option.name == 'Colour' %}
                          style="{% if value.swatch.color %}background:{{ value.swatch.color }};{% endif %}"
                          title="{{ value }}"
                        {% endif %}>
                  {% if option.name == 'Color' or option.name == 'Colour' %}
                    {% if value.swatch.image %}
                      <img src="{{ value.swatch.image | image_url: width: 40 }}" alt="{{ value }}" width="20" height="20" loading="lazy">
                    {% else %}
                      {{ value }}
                    {% endif %}
                  {% else %}
                    {{ value }}
                  {% endif %}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endunless %}

    <!-- Quantity -->
    <div class="pdp-qty-row">
      <div class="pdp-qty-label">Quantity</div>
      <div class="pdp-qty">
        <button class="pdp-qty-btn" id="pdp-qty-minus" aria-label="Decrease">−</button>
        <input class="pdp-qty-input" type="number" id="pdp-qty" name="quantity" value="1" min="1" readonly>
        <button class="pdp-qty-btn" id="pdp-qty-plus" aria-label="Increase">+</button>
      </div>
    </div>

    <!-- Selling plans -->
    {% if product.selling_plan_groups.size > 0 %}
      <div class="pdp-selling-plans">
        {% for group in product.selling_plan_groups %}
          <div class="pdp-selling-plan-group">
            <div class="pdp-selling-plan-label">{{ group.name }}</div>
            <div class="pdp-selling-plan-options">
              <label class="pdp-selling-plan-option">
                <input type="radio" name="selling_plan_{{ group.id }}" value="" data-selling-plan-group="{{ group.id }}" checked> One-time purchase
              </label>
              {% for plan in group.selling_plans %}
                <label class="pdp-selling-plan-option">
                  <input type="radio" name="selling_plan_{{ group.id }}" value="{{ plan.id }}" data-selling-plan-group="{{ group.id }}"> {{ plan.name }}
                </label>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <!-- Add to cart form -->
    {% form 'product', product, id: 'pdp-form', class: 'pdp-form' %}
      <input type="hidden" name="id" id="pdp-variant-id" value="{{ product.selected_or_first_available_variant.id }}">
      <input type="hidden" name="quantity" id="pdp-form-qty" value="1">
      <input type="hidden" name="selling_plan" id="pdp-selling-plan" value="">

      <div class="pdp-actions">
        <button type="submit" class="pdp-atc {% unless product.available %}pdp-atc--disabled{% endunless %}"
                id="pdp-atc" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Add to cart
          {% else %}
            Sold out
          {% endif %}
        </button>
        <button type="button" class="pdp-wishlist" id="pdp-wishlist" aria-label="Save to wishlist">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>

      <!-- Accelerated checkout (Shop Pay, Apple Pay, Google Pay etc.) -->
      <div class="pdp-payment-btns">
        {{ form | payment_button }}
      </div>

      <!-- cart notification -->
      <div class="pdp-atc-confirm" id="pdp-atc-confirm">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><polyline points="20 6 9 17 4 12"/></svg>
        Added to cart
      </div>
    {% endform %}

    <!-- Shop Pay Installments -->
    <div class="pdp-installments">
      {{ product | payment_terms }}
    </div>

    <!-- Pickup availability -->
    <div class="pdp-pickup" id="pdp-pickup">
      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- if current_variant.store_availabilities.size > 0 -%}
        {%- for availability in current_variant.store_availabilities -%}
          <div class="pdp-pickup-location">
            <span class="pdp-pickup-status {% if availability.available %}available{% else %}unavailable{% endif %}">
              {% if availability.available %}Available{% else %}Unavailable{% endif %}
            </span>
            for pickup at <strong>{{ availability.location.name }}</strong>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Follow on Shop -->
    <div class="pdp-follow-shop">
      {{ shop | login_button }}
    </div>

    <!-- Trust badges -->
    <div class="pdp-trust">
      <div class="pdp-trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span data-i18n="secure-checkout">Secure checkout</span>
      </div>
      <div class="pdp-trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        <span data-i18n="free-shipping">Free shipping</span>
      </div>
      <div class="pdp-trust-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>
        <span data-i18n="easy-returns">Easy returns</span>
      </div>
    </div>

    <!-- Description accordion -->
    <div class="pdp-accordion">
      <button class="pdp-accordion-trigger" aria-expanded="true">
        Description
        <svg class="pdp-accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><polyline points="18 15 12 9 6 15"/></svg>
      </button>
      <div class="pdp-accordion-body open">
        <div class="pdp-description rte">{{ product.description }}</div>
      </div>

      {% if product.metafields.custom.details != blank %}
        <button class="pdp-accordion-trigger" aria-expanded="false">
          Details & Specs
          <svg class="pdp-accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
        <div class="pdp-accordion-body">
          <div class="pdp-description rte">{{ product.metafields.custom.details }}</div>
        </div>
      {% endif %}

      {% if product.metafields.custom.shipping != blank %}
        <button class="pdp-accordion-trigger" aria-expanded="false">
          Shipping & Returns
          <svg class="pdp-accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
        <div class="pdp-accordion-body">
          <div class="pdp-description rte">{{ product.metafields.custom.shipping }}</div>
        </div>
      {% endif %}
    </div>

    <!-- Share -->
    <div class="pdp-share">
      <span class="pdp-share-label">Share</span>
      <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="pdp-share-btn" aria-label="Share on X">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="pdp-share-btn" aria-label="Share on Facebook">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
    </div>

  </div>
</div>

<!-- Related products -->
{% if recommendations.performed and recommendations.products_count > 0 %}
  <div class="pdp-related section">
    <div class="s-label" style="margin-bottom:40px;">You might also like</div>
    <div class="pdp-related-grid">
      {% for rp in recommendations.products limit: 4 %}
        <a href="{{ rp.url }}" class="pdp-related-card">
          {% if rp.featured_image %}
            <div class="pdp-related-img-wrap">
              <img src="{{ rp.featured_image | image_url: width: 500 }}" alt="{{ rp.featured_image.alt | escape }}" width="500" height="500" loading="lazy" class="pdp-related-img">
            </div>
          {% else %}
            <div class="pdp-related-img-wrap pdp-related-placeholder"></div>
          {% endif %}
          <div class="pdp-related-info">
            <div class="pdp-related-title">{{ rp.title }}</div>
            <div class="pdp-related-price">{{ rp.price | money }}</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
{% endif %}

<!-- Sticky ATC bar -->
<div class="sticky-atc" id="sticky-atc">
  <div class="sticky-atc-inner">
    {% if product.featured_image %}
      <img src="{{ product.featured_image | image_url: width: 80 }}" alt="" class="sticky-atc-img" width="80" height="80" loading="lazy">
    {% endif %}
    <div class="sticky-atc-info">
      <div class="sticky-atc-title">{{ product.title }}</div>
      <div class="sticky-atc-price">{{ product.selected_or_first_available_variant.price | money }}</div>
    </div>
    <button class="sticky-atc-btn" id="sticky-atc-btn" {% unless product.available %}disabled{% endunless %}>
      {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
    </button>
  </div>
</div>

<script id="product-json" type="application/json">
  {{ product | json }}
</script>

<!-- App blocks -->
<div class="pdp-app-blocks">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when '@app' %}
        {% render block %}
      {% when 'custom_liquid' %}
        <div class="pdp-custom-liquid" {{ block.shopify_attributes }}>{{ block.settings.custom_liquid }}</div>
    {% endcase %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Product information",
  "blocks": [
    { "type": "@app" },
    {
      "type": "custom_liquid",
      "name": "Custom Liquid",
      "settings": [
        { "type": "liquid", "id": "custom_liquid", "label": "Liquid code" }
      ]
    }
  ],
  "settings": []
}
{% endschema %}
