<!-- Video Background Hero — alternative to canvas hero -->
<section id="section-hero" class="hero hero-video-section" data-section-num="001">

  <!-- Video background -->
  {% if section.settings.video != blank %}
    <video class="hero-video-bg" autoplay muted loop playsinline preload="metadata"
           poster="{{ section.settings.video_poster | image_url: width: 1920 }}">
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
    </video>
  {% elsif section.settings.video_url != blank %}
    <div class="hero-video-embed">
      <iframe src="{{ section.settings.video_url }}?autoplay=1&mute=1&loop=1&controls=0&playlist={{ section.settings.video_url | split: '/' | last }}"
              allow="autoplay" frameborder="0" allowfullscreen></iframe>
    </div>
  {% elsif section.settings.fallback_image != blank %}
    <div class="hero-video-img-fallback">
      <img src="{{ section.settings.fallback_image | image_url: width: 1920 }}"
           alt="Hero background" loading="eager">
    </div>
  {% endif %}

  <div class="hero-video-overlay" style="background: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="hero-video-scanlines"></div>

  <div class="hero-fc hero-fc-tl"></div>
  <div class="hero-fc hero-fc-tr"></div>
  <div class="hero-fc hero-fc-bl"></div>
  <div class="hero-fc hero-fc-br"></div>

  <div class="hero-meta-right">
    <div class="hero-meta-num">001</div>
    <span class="hero-meta-tag">{{ section.settings.meta_tag | default: 'Scene One' }}</span>
  </div>

  <div class="hero-content" id="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-dot"></span>
      <span class="hero-eyebrow-text">{{ section.settings.eyebrow | default: 'Filmmaker · Scriptwriter · Creative Director' }}</span>
    </div>

    <h1 class="hero-name" id="hero-name"
        data-text="{{ section.settings.name_line1 | default: 'Omar' }} {{ section.settings.name_line2 | default: 'Emad El Din' }}">
      <span class="hero-name-line"><span>{{ section.settings.name_line1 | default: 'Omar' }}</span></span>
      <span class="hero-name-line italic"><span>{{ section.settings.name_line2 | default: 'Emad El Din' }}</span></span>
    </h1>

    <p class="hero-tagline">{{ section.settings.tagline | default: 'Visual stories told with intention — from the written word to the final frame.' }}</p>

    <div class="hero-chips">
      {% for block in section.blocks %}
        {% if block.type == 'chip' %}
          <span class="hero-chip" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="hero-scroll">
    <div class="hero-scroll-track"><div class="hero-scroll-thumb"></div></div>
    <span class="hero-scroll-lbl">{{ section.settings.scroll_label | default: 'Scroll' }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Hero — Video Background",
  "settings": [
    {
      "type": "header",
      "content": "Video background"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video file (Shopify-hosted)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube/Vimeo embed URL",
      "info": "Used if no Shopify video is uploaded"
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video poster / fallback image"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Static fallback image (if no video)"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay colour",
      "default": "#040404"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "name_line1",
      "label": "Name — line 1",
      "default": "Omar"
    },
    {
      "type": "text",
      "id": "name_line2",
      "label": "Name — line 2 (italic)",
      "default": "Emad El Din"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Filmmaker · Scriptwriter · Creative Director"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Visual stories told with intention — from the written word to the final frame."
    },
    {
      "type": "text",
      "id": "meta_tag",
      "label": "Side meta label",
      "default": "Scene One"
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Scroll label",
      "default": "Scroll"
    }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Skill chip",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Scriptwriter"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero — Video Background",
      "blocks": [
        { "type": "chip", "settings": { "label": "Scriptwriter" } },
        { "type": "chip", "settings": { "label": "Film Director" } },
        { "type": "chip", "settings": { "label": "Creative Director" } }
      ]
    }
  ]
}
{% endschema %}
