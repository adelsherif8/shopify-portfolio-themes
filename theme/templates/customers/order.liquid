{% layout 'theme' %}

<div class="account-page section">

  <div class="account-header">
    <a href="{{ routes.account_url }}" class="account-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Account
    </a>
    <div class="account-label">Order {{ order.name }}</div>
  </div>

  <div class="order-meta-row">
    <div class="order-meta-item">
      <div class="order-meta-key">Date</div>
      <div class="order-meta-val">{{ order.created_at | date: '%B %d, %Y' }}</div>
    </div>
    <div class="order-meta-item">
      <div class="order-meta-key">Status</div>
      <div class="order-meta-val order-status--{{ order.financial_status }}">{{ order.financial_status | capitalize }}</div>
    </div>
    <div class="order-meta-item">
      <div class="order-meta-key">Fulfillment</div>
      <div class="order-meta-val">{{ order.fulfillment_status | capitalize | default: 'Unfulfilled' }}</div>
    </div>
  </div>

  <!-- Line items -->
  <div class="order-items">
    <div class="order-items-head">
      <span>Product</span>
      <span>Qty</span>
      <span>Price</span>
    </div>
    {% for line_item in order.line_items %}
      <div class="order-line">
        <div class="order-line-product">
          {% if line_item.image %}
            <img src="{{ line_item.image | image_url: width: 80 }}" alt="{{ line_item.title | escape }}" class="order-line-img" width="80" height="80" loading="lazy">
          {% else %}
            <div class="order-line-img-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="24" height="24" style="opacity:.2;color:var(--gold)"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {% endif %}
          <div class="order-line-info">
            <div class="order-line-title">{{ line_item.title }}</div>
            {% unless line_item.variant.title == 'Default Title' %}
              <div class="order-line-variant">{{ line_item.variant.title }}</div>
            {% endunless %}
            {% if line_item.selling_plan_allocation %}
              <div class="order-line-variant">{{ line_item.selling_plan_allocation.selling_plan.name }}</div>
            {% endif %}
            {% if line_item.unit_price %}
              <div class="order-line-unit-price">{{ line_item.unit_price | money }}/{{ line_item.unit_price_measurement.reference_value }}{{ line_item.unit_price_measurement.reference_unit }}</div>
            {% endif %}
            {% if line_item.fulfillment %}
              <div class="order-line-tracking">
                Tracking:
                {% if line_item.fulfillment.tracking_url %}
                  <a href="{{ line_item.fulfillment.tracking_url }}" target="_blank" rel="noopener">{{ line_item.fulfillment.tracking_number }}</a>
                {% else %}
                  {{ line_item.fulfillment.tracking_number }}
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
        <div class="order-line-qty">× {{ line_item.quantity }}</div>
        <div class="order-line-price">{{ line_item.final_line_price | money }}</div>
      </div>
    {% endfor %}
  </div>

  <!-- Totals -->
  <div class="order-totals">
    <div class="order-totals-row">
      <span>Subtotal</span>
      <span>{{ order.subtotal_price | money }}</span>
    </div>
    {% for discount in order.discounts %}
      <div class="order-totals-row order-discount">
        <span>Discount ({{ discount.code }})</span>
        <span>−{{ discount.amount | money }}</span>
      </div>
    {% endfor %}
    {% for shipping_method in order.shipping_methods %}
      <div class="order-totals-row">
        <span>Shipping ({{ shipping_method.title }})</span>
        <span>{{ shipping_method.price | money }}</span>
      </div>
    {% endfor %}
    {% for tax_line in order.tax_lines %}
      <div class="order-totals-row">
        <span>{{ tax_line.title }} ({{ tax_line.rate | times: 100 }}%)</span>
        <span>{{ tax_line.price | money }}</span>
      </div>
    {% endfor %}
    <div class="order-totals-row order-totals-grand">
      <span>Total</span>
      <span>{{ order.total_price | money }}</span>
    </div>
  </div>

  <!-- Addresses -->
  <div class="order-addresses">
    {% if order.shipping_address %}
      <div class="order-address-block">
        <div class="account-section-label">Shipping address</div>
        {{ order.shipping_address | format_address }}
      </div>
    {% endif %}
    {% if order.billing_address %}
      <div class="order-address-block">
        <div class="account-section-label">Billing address</div>
        {{ order.billing_address | format_address }}
      </div>
    {% endif %}
  </div>

</div>
