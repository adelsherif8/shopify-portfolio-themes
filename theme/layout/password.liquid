<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  <meta name="description" content="{{ shop.description | escape }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,200;0,300;1,200;1,300&family=Space+Mono:wght@400&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {% if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {% endif %}
  {{ content_for_header }}
</head>
<body>
  <div id="global-spotlight" class="global-spotlight"></div>

  {{ content_for_layout }}
</body>
</html>
